# Copy to backend/.env and fill in. See the README "Running the project" section.

# ─── Required ────────────────────────────────────────────────────────────────
# App metadata store (accounts, connections, conversations). MySQL or Postgres.
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/sql_agent
GROQ_API_KEY=your-groq-api-key
SECRET_KEY=change-me-to-a-long-random-string

# Encrypts stored connected-database passwords. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If this is lost or changed, existing connections cannot be decrypted.
CREDENTIALS_KEY=your-fernet-key

# ─── Auth token lifetimes (optional) ─────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── App database pool (optional) ────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── CORS (optional) ─────────────────────────────────────────────────────────
# Browser origins allowed to call the API, comma separated. Defaults to the Vite
# dev server. Set this when the frontend is served from anywhere else.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Logfire (optional; without a token nothing is sent, console output only) ─
# Normally there is nothing to set here: `uv run logfire projects new` (from the
# repo root) writes .logfire/logfire_credentials.json and the app reads it.
# LOGFIRE_TOKEN overrides that file, so leave it unset unless you mean it -- a
# placeholder value here counts as "a token" and breaks sending.
# LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=dev
# Set to false to silence local console output.
LOGFIRE_CONSOLE=true

# ─── LangSmith tracing (optional; remove if you don't use LangSmith) ─────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-key
LANGCHAIN_PROJECT=sql_agent
